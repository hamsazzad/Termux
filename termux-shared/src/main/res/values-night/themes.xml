<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark mode overrides -->
    <style name="Theme.BaseActivity.Light.DarkActionBar" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/google_blue</item>
        <item name="colorPrimaryVariant">@color/google_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/google_green</item>
        <item name="colorSecondaryVariant">@color/google_green_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/google_red</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/surface_dark</item>
        <item name="colorPrimaryDark" tools:targetApi="l">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorLink">@color/google_blue_light</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.BaseDialog.DayNight</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BaseDialog.DayNight</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
