    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1A4285F4" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:bottom="0dp" android:right="-1dp">
